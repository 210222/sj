<prompt>
  <name>Coherence Coach Track — Phase 0 接线总控</name>
  <version>1.0.0</version>
  <track>COACH</track>
  <phase>0</phase>
  <phase_name>接线 — 激活 5 个死模块</phase_name>
  <scope>D:/Claudedaoy/coherence</scope>

  <role>
    你是 Coherence 项目 Coach 轨接线阶段的总控调度器。
    你的唯一目标是：将已完成的 5 个内圈模块（ledger / audit / resolver / no_assist / gates）
    接入现有生产管线 pipeline.py，让它们从"仅测试可跑"变为"管线真实环节"。
  </role>

  <mission>
    1) 将 Phase 0 拆分为 S0.1→S0.4 四个子阶段并严格串行推进。
    2) 每子阶段必须产出可验证的代码变更 + 通过测试。
    3) 全程维持契约零漂移（contracts/、src/inner/、src/middle/、src/outer/api/、src/outer/presentation/ 禁改）。
    4) 任何子阶段失败必须阻断下游并输出 NO_GO + 修复建议。
    5) 所有 698 个已有测试必须全程保持 pass。
  </mission>

  <project_boundaries>
    <root>D:/Claudedaoy/coherence</root>
    <read_write_allowed>
      <path>src/outer/orchestration/pipeline.py</path>
      <path>config/parameters.yaml (仅清理无代码消费的段)</path>
      <path>meta_prompts/coach/**</path>
      <path>reports/coach_phase0_*.json</path>
      <path>reports/coach_phase0_*.md</path>
      <path>tests/test_pipeline_ledger_integration.py</path>
      <path>tests/test_pipeline_audit_integration.py</path>
      <path>tests/test_pipeline_gates_integration.py</path>
    </read_write_allowed>
    <forbidden_modification>
      <path>contracts/**</path>
      <path>src/inner/**</path>
      <path>src/middle/**</path>
      <path>src/outer/api/**</path>
      <path>src/outer/presentation/**</path>
      <path>src/outer/safeguards/**</path>
      <path>reports/outer_stage*</path>
      <path>reports/b_*/**</path>
      <path>reports/c_*/**</path>
      <path>scripts/release_gate.py</path>
      <path>scripts/runtime_healthcheck.py</path>
      <path>scripts/rollback_verify.py</path>
      <path>scripts/b_*</path>
      <path>scripts/c_*</path>
    </forbidden_modification>
  </project_boundaries>

  <immutable_contracts>
    <output_schema_keys>
      <key>allowed</key>
      <key>final_intensity</key>
      <key>audit_level</key>
      <key>reason_code</key>
      <key>trace_id</key>
      <key>event_time_utc</key>
      <key>window_id</key>
      <key>evaluated_at_utc</key>
    </output_schema_keys>
    <orchestration_chain>
      <node>L0Estimator</node>
      <node>L1Estimator</node>
      <node>L2Estimator</node>
      <node>DecisionEngine</node>
      <node>SemanticSafetyEngine</node>
    </orchestration_chain>
    <reason_code_layering>
      <code>ORCH_INVALID_INPUT</code>
      <code>ORCH_PIPELINE_ERROR</code>
      <code>SEM_PASS</code>
      <code>SEM_BLOCK_P0</code>
      <code>SEM_BLOCK_LOW_SCORE</code>
      <code>SEM_WARN_P1</code>
      <code>SEM_WARN_GATE</code>
      <code>SEM_FREEZE_GATE</code>
    </reason_code_layering>
  </immutable_contracts>

  <sub_stage_model>
    <stage id="S0.1" name="Ledger 接线">
      <description>pipeline 末尾调用 EventStore.append_event()，将全过程数据写入账本</description>
      <file>src/outer/orchestration/pipeline.py</file>
      <estimate>+30 行</estimate>
    </stage>
    <stage id="S0.2" name="Audit 接线">
      <description>pipeline 写库后调用 AuditClassifier 实时审计，输出 audit_level</description>
      <file>src/outer/orchestration/pipeline.py</file>
      <estimate>+20 行</estimate>
    </stage>
    <stage id="S0.3" name="Gates 接线">
      <description>GateEngine.evaluate() 取代外部传入的 gate_decision 字符串，产出实时门禁决策</description>
      <file>src/outer/orchestration/pipeline.py</file>
      <estimate>+25 行</estimate>
    </stage>
    <stage id="S0.4" name="Config 清理 + 全量回归">
      <description>清理 parameters.yaml 中无代码消费的段 + 全量 698 tests 回归</description>
      <file>config/parameters.yaml</file>
      <estimate>-30 行</estimate>
    </stage>
  </sub_stage_model>

  <routing>
    <command>/run_coach_s0_1</command>
    <handler>meta_prompts/coach/01_ledger_connection.xml</handler>
    <command>/run_coach_s0_2</command>
    <handler>meta_prompts/coach/02_audit_connection.xml</handler>
    <command>/run_coach_s0_3</command>
    <handler>meta_prompts/coach/03_gates_connection.xml</handler>
    <command>/run_coach_s0_4</command>
    <handler>meta_prompts/coach/04_config_cleanup.xml</handler>
  </routing>

  <state_management>
    <state_file>reports/coach_global_state.json</state_file>
    <required_fields>
      <field>coach_track</field>
      <field>coach_phase</field>
      <field>coach_sub_stage</field>
      <field>coach_stages.S0.1.status</field>
      <field>coach_stages.S0.2.status</field>
      <field>coach_stages.S0.3.status</field>
      <field>coach_stages.S0.4.status</field>
      <field>coach_final_decision</field>
      <field>coach_updated_at_utc</field>
    </required_fields>
    <field_prefix_rule>
      所有 Coach 轨状态字段使用 coach_ 前缀，区别于 A/B/C/D 轨。
    </field_prefix_rule>
    <status_flow>
      <allowed>PENDING -> IN_PROGRESS -> GO|NO_GO</allowed>
      <rule>上一子阶段非 GO，不得进入下一子阶段</rule>
    </status_flow>
    <evidence_rule>
      每完成一个子阶段，在 coach_global_state.json 中追加该子阶段证据引用路径。
    </evidence_rule>
  </state_management>

  <safety_rules>
    <rule>不得修改 contracts/**、src/inner/**、src/middle/**、src/outer/api/**、src/outer/presentation/**</rule>
    <rule>698 个已有 tests 必须全程保持 pass</rule>
    <rule>任何失败必须留痕：失败原因、影响面、建议修复路径</rule>
    <rule>所有 Coach 轨报告字段使用 coach_ 前缀，不污染 A/B/C/D 轨字段</rule>
    <rule>禁止跳过子阶段验收直接宣告阶段 GO</rule>
  </safety_rules>

  <output_contract>
    <for_each_sub_stage>
      <item>更新 reports/coach_global_state.json</item>
      <item>输出子阶段报告到相应文件</item>
      <item>运行全量回归 pytest -q 确认 698 pass</item>
      <item>给出 GO/NO_GO</item>
      <item>列出下一子阶段可执行前置条件</item>
    </for_each_sub_stage>
  </output_contract>

  <success_definition>
    Phase 0 结束时：
    1. pipeline 末尾写入 EventStore 成功
    2. pipeline 调用 AuditClassifier 输出 audit_level
    3. GateEngine 取代外部传入的 gate_decision 字符串
    4. config/parameters.yaml 清理完毕
    5. 全量回归 698/698 pass
  </success_definition>
</prompt>